# Email Configuration
# Get your Gmail App Password from https://myaccount.google.com/apppasswords
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Report Configuration (recipient email for fraud alerts)
REPORT_RECIPIENT=admin@example.com

# SMTP Configuration (leave as default for Gmail)
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587

# App Configuration
ENVIRONMENT=development
DEBUG=False
